    brief: docs/maintenance/AUTO-2.md
    preregistered_acceptance:
      - "tests/test_config_validation.py::test_default_config_validates_clean PASSES"
      - "tests/test_config_validation.py::test_growth_config_validates_clean PASSES"
      - "tests/test_config_validation.py::test_post_init_rejects_negative_box_size PASSES"
      - "tests/test_config_validation.py::test_post_init_rejects_zero_dt PASSES"
      - "tests/test_config_validation.py::test_post_init_rejects_r1_geq_r2 PASSES"
      - "tests/test_config_validation.py::test_post_init_rejects_freq_tolerance_out_of_range PASSES"
      - "tests/test_config_validation.py::test_existing_test_configs_all_validate PASSES"
    time_budget_hours: 12
    status: queued
    attempts: 0
    blockers: []
    created: 2026-05-13

  - id: AUTO-3
    title: Deterministic regression snapshot for default growth config
    brief: docs/maintenance/AUTO-3.md
    preregistered_acceptance:
      - "tests/test_regression_snapshot.py::test_snapshot_file_exists PASSES"
      - "tests/test_regression_snapshot.py::test_config_hash_matches_snapshot PASSES"
      - "tests/test_regression_snapshot.py::test_growth_default_seed42_30s_matches_snapshot PASSES"
      - "tests/test_regression_snapshot.py::test_growth_default_seed43_differs_from_snapshot PASSES"
      - "tests/test_regression_snapshot.py::test_snapshot_captures_within_30_seconds PASSES"
